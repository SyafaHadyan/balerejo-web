{
  "name": "balerejo-web",
  "private": true,
  "packageManager": "npm@11.18.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "size": "size-limit",
    "spellcheck": "cspell lint --config cspell.json"
  },
  "size-limit": [
    {
      "name": "main — shared JS",
      "path": "apps/main/.next/static/chunks/*.js",
      "limit": "130 kB"
    },
    {
      "name": "umkm — shared JS",
      "path": "apps/umkm/.next/static/chunks/*.js",
      "limit": "130 kB"
    }
  ],
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@size-limit/file": "^12.1.0",
    "cspell": "^10.0.1",
    "size-limit": "^12.1.0",
    "turbo": "^2.10.5"
  },
  "dependencies": {
    "sharp": "^0.35.3"
  }
}
